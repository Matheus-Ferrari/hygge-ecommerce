# Copie este arquivo para .secret.local e preencha com os valores reais.
# O arquivo .secret.local é usado pelo Firebase Emulator para simular os Secrets
# e já está no .gitignore (via *.local). NUNCA commite .secret.local.
#
# Para configurar os secrets em produção, use:
#   firebase functions:secrets:set MP_KEY
#   firebase functions:secrets:set BLING_CLIENT_ID
#   firebase functions:secrets:set BLING_CLIENT_SECRET
#   firebase functions:secrets:set MELHOR_ENVIO_TOKEN
#   firebase functions:secrets:set MP_WEBHOOK_SECRET
#
# O MP_WEBHOOK_SECRET é gerado no painel do Mercado Pago:
#   Painel MP → Seu negócio → Webhooks → Criar/Editar webhook → "Secret"

MP_KEY=TEST-000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
BLING_CLIENT_ID=your-bling-client-id
BLING_CLIENT_SECRET=your-bling-client-secret
MELHOR_ENVIO_TOKEN=your-melhor-envio-token
MP_WEBHOOK_SECRET=your-mp-webhook-secret
