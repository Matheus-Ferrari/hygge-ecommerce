rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // 1. Assets visuais do site (banners, UI/UX) — somente leitura pública.
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // 2. Imagens dos produtos — somente leitura pública.
    match /produtos/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // 3. Qualquer outra pasta futura exige autenticação para leitura e escrita.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
